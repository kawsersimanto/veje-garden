          "label": "Banner Image"
        },
        {
          "type": "richtext",
          "id": "banner_title",
          "label": "Banner Title"
        },
        {
          "type": "richtext",
          "id": "banner_description",
          "label": "Banner Description"
        },
        {
          "type": "url",
