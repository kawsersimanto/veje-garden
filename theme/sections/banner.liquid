          "label": "Banner Link"
        },
        {
          "type": "text",
          "id": "banner_button_text",
          "label": "Banner Button Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Slider",
      "category": "Image",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
