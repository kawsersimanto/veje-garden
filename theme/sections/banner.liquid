<div
  class="section section--page-width"
>
  <div class="banner-row">
    <div class="swiper banner-collection tw:w-full tw:max-w-full">
      <div class="swiper-wrapper">
        <div class="swiper-slide">Slide 1</div>
        <div class="swiper-slide">Slide 2</div>
        <div class="swiper-slide">Slide 3</div>
      </div>
    </div>
  </div>
</div>

<script>
  const bannerSlider = new Swiper('.banner-collection', {
    slidesPerView: 1,
    effect: 'fade',
    fadeEffect: {
      crossFade: true,
    },
  });
</script>

