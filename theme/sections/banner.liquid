<div
  class="section section--page-width"
>
  <div class="banner-row">
    <div class="swiper banner-collection tw:w-full tw:max-w-full">
      <div class="swiper-wrapper">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <div class="swiper-slide">
              <a
                href="{{ block.settings.link }}"
                class="tw:rounded-lg tw:overflow-hidden tw:block tw:relative tw:h-160"
              >
                {% if block.settings.image %}
                  <img
                    src="{{ block.settings.image | image_url: width: 2000 }}"
                    width="2000"
                    height="2000"
                    alt="{{ block.settings.banner_title | strip_html }}"
                    class="tw:w-full! tw:h-full! tw:object-cover tw:object-bottom tw:hidden tw:md:block"
                  >
                {% endif %}

                {% if block.settings.mobile_image %}
                  <img
                    src="{{ block.settings.mobile_image | image_url: width: 2000 }}"
                    width="2000"
                    height="2000"
                    alt="{{ block.settings.banner_title | strip_html }}"
                    class="tw:w-full! tw:h-full! tw:object-cover tw:object-bottom tw:block tw:md:hidden"
                  >
                {% endif %}
                <div class="tw:absolute tw:inset-0 tw:p-10 tw:flex tw:flex-col tw:items-start tw:justify-center tw:max-w-130 tw:gap-8">
                  <div class="tw:flex tw:flex-col tw:gap-4">
                    <div class="tw:text-6xl!">{{ block.settings.banner_title }}</div>
                    <p class="tw:text-base!">{{ block.settings.banner_description | strip_html }}</p>
                  </div>
                  <div class="button">{{ block.settings.banner_button_text }}</div>
                </div>
              </a>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  const bannerSlider = new Swiper('.banner-collection', {
    slidesPerView: 1,
    effect: 'fade',
    fadeEffect: {
      crossFade: true,
    },
  });
</script>

{% schema %}
{
  "name": "Banner Slider",
  "tag": "section",
  "class": "banner-slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Banner Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Banner Image"
        },
        {
          "type": "richtext",
          "id": "banner_title",
          "label": "Banner Title"
        },
        {
          "type": "richtext",
          "id": "banner_description",
          "label": "Banner Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Banner Link"
        },
        {
          "type": "text",
          "id": "banner_button_text",
          "label": "Banner Button Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Slider",
      "category": "Image",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
